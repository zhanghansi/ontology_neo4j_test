#################################################################


###  http://purl.obolibrary.org/obo/DOID_3526

obo:DOID_3526 rdf:type owl:Class ;
              
              rdfs:label "cerebral infarction" ;
              
              rdfs:subClassOf [ rdf:type owl:Class ;
                                owl:intersectionOf ( obo:OGMS_0000031
                                                     [ rdf:type owl:Restriction ;
                                                       owl:onProperty obo:RO_0000053 ;
                                                       owl:allValuesFrom obo:MF_0000016
                                                     ]
                                                   )
                              ] ;
              
              oboInOwl:hasDbXref "ICD10CM:I63" ,
                                 "url:https://en.wikipedia.org/wiki/Cerebral_infarction" ;
              
              obo:IAO_0000115 "A cerebrovascular disease that is characterized by an area of necrotic tissue in the brain resulting from a blockage or narrowing in the arteries supplying blood and oxygen to the brain." ;
              
              oboInOwl:hasExactSynonym "CVA - Cerebral infarction"@en ;
              
              oboInOwl:hasDbXref "SNOMEDCT_US_2020_09_01:195188006" ;
              
              oboInOwl:hasExactSynonym "Cerebral infarction"@en ;
              
              oboInOwl:hasDbXref "UMLS_CUI:C0007785" ;
              
              obo:IAO_0000412 "http://purl.obolibrary.org/obo/doid/releases/2021-04-29/doid.owl" ;
              
              oboInOwl:hasDbXref "OMIM:601367" ;
              
              oboInOwl:hasExactSynonym "Cerebral infarct"@en ;
              
              oboInOwl:hasDbXref "NCI:C50486" ;
              
              oboInOwl:hasOBONamespace "disease_ontology" ;
              
              oboInOwl:id "DOID:3526" ;
              
              oboInOwl:hasDbXref "MESH:D002544" ;
              
              dc:type obo:ECO_0007638 ;
              
              oboInOwl:inSubset <http://purl.obolibrary.org/obo/doid#NCIthesaurus> .



###  http://purl.obolibrary.org/obo/IAO_0000027

obo:IAO_0000027 rdf:type owl:Class ;
                
                rdfs:label "data item"@en ;
                
                rdfs:subClassOf obo:IAO_0000030 ;
                
                obo:IAO_0000116 "2/2/2009 Alan and Bjoern discussing FACS run output data. This is a data item because it is about the cell population. Each element records an event and is typically further composed a set of measurment data items that record the fluorescent intensity stimulated by one of the lasers."@en ;
                
                obo:IAO_0000115 "An information content entity that is intended to be a truthful statement about something (modulo, e.g., measurement precision or other systematic errors) and is constructed/acquired by a method which reliably tends to produce (approximately) truthful statements."@en ;
                
                obo:IAO_0000412 "http://purl.obolibrary.org/obo/iao/2020-12-09/iao.owl" ;
                
                obo:IAO_0000116 "2014-03-31: See discussion at http://odontomachus.wordpress.com/2014/03/30/aboutness-objects-propositions/" ,
                                "2009-03-16: data item deliberatly ambiguous: we merged data set and datum to be one entity, not knowing how to define singular versus plural. So data item is more general than datum."@en ,
                                "2009-03-16: removed datum as alternative term as datum specifically refers to singular form, and is thus not an exact synonym."@en ;
                
                obo:IAO_0000112 "Data items include counts of things, analyte concentrations, and statistical summaries."@en ;
                
                obo:IAO_0000116 """JAR: datum     -- well, this will be very tricky to define, but maybe some 
information-like stuff that might be put into a computer and that is 
meant, by someone, to denote and/or to be interpreted by some 
process... I would include lists, tables, sentences... I think I might 
defer to Barry, or to Brian Cantwell Smith

JAR: A data item is an approximately justified approximately true approximate belief"""@en ;
                
                obo:IAO_0000117 "PERSON: Alan Ruttenberg"@en ,
                                "PERSON: Chris Stoeckert"@en ,
                                "PERSON: Jonathan Rees"@en ;
                
                obo:IAO_0000118 "data"@en ;
                
                obo:IAO_0000111 "data item"@en ;
                
                obo:IAO_0000114 obo:IAO_0000125 .



###  http://purl.obolibrary.org/obo/IAO_0000030

obo:IAO_0000030 rdf:type owl:Class ;
                
                rdfs:label "information content entity"@en ;
                
                rdfs:subClassOf obo:BFO_0000031 ;
                
                obo:IAO_0000116 "2014-03-10: The use of \"thing\" is intended to be general enough to include universals and configurations (see https://groups.google.com/d/msg/information-ontology/GBxvYZCk1oc/-L6B5fSBBTQJ)."@en ;
                
                obo:IAO_0000115 "A generically dependent continuant that is about some thing."@en ;
                
                obo:IAO_0000412 "http://purl.obolibrary.org/obo/iao/2020-12-09/iao.owl" ;
                
                obo:IAO_0000112 "Examples of information content entites include journal articles, data, graphical layouts, and graphs."@en ;
                
                obo:IAO_0000119 "OBI_0000142"@en ;
                
                obo:IAO_0000117 "PERSON: Chris Stoeckert"@en ;
                
                obo:IAO_0000111 "information content entity"@en ;
                
                obo:IAO_0000116 """information_content_entity 'is_encoded_in' some digital_entity in obi before split (040907). information_content_entity 'is_encoded_in' some physical_document in obi before split (040907).

Previous. An information content entity is a non-realizable information entity that 'is encoded in' some digital or physical entity."""@en ;
                
                obo:IAO_0000114 obo:IAO_0000122 .



###  http://purl.obolibrary.org/obo/MF_0000016

obo:MF_0000016 rdf:type owl:Class ;
               
               rdfs:label "human being" ;
               
               rdfs:subClassOf [ rdf:type owl:Class ;
                                 owl:intersectionOf ( obo:BFO_0000040
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty obo:RO_0000053 ;
                                                        owl:someValuesFrom obo:OMRSE_00000011
                                                      ]
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty obo:RO_0000056 ;
                                                        owl:someValuesFrom obo:OGMS_0000104
                                                      ]
                                                    )
                               ] ;
               
               obo:IAO_0000118 "person" ;
               
               obo:IAO_0000115 "A member of the species Homo Sapiens." ;
               
               obo:IAO_0000412 "http://purl.obolibrary.org/obo/MF/2020-08-07/MF.owl" .



###  http://purl.obolibrary.org/obo/OGMS_0000031

obo:OGMS_0000031 rdf:type owl:Class ;
                 
                 rdfs:label "disease" ;
                 
                 rdfs:subClassOf obo:BFO_0000016 ;
                 
                 obo:IAO_0000412 "https://github.com/OGMS/ogms/releases/tag/2021-04-20" ;
                 
                 obo:IAO_0000117 "Albert Goldfain" ;
                 
                 obo:IAO_0000232 "creation date: 2009-06-23T11:21:20Z" ;
                 
                 obo:IAO_0000115 "A disposition (i) to undergo pathological processes that (ii) exists in an organism because of one or more disorders in that organism."@en ;
                 
                 obo:IAO_0000119 "http://ontology.buffalo.edu/medo/Disease_and_Diagnosis.pdf" .



###  http://purl.obolibrary.org/obo/OGMS_0000073

obo:OGMS_0000073 rdf:type owl:Class ;
                 
                 rdfs:label "diagnosis" ;
                 
                 obo:IAO_0000117 "Albert Goldfain" ;
                 
                 obo:IAO_0000412 "https://github.com/OGMS/ogms/releases/tag/2021-04-20" ;
                 
                 obo:IAO_0000115 "The representation of a conclusion of a diagnostic process."@en ;
                 
                 obo:IAO_0000119 "http://ontology.buffalo.edu/medo/Disease_and_Diagnosis.pdf" ;
                 
                 obo:IAO_0000232 "creation date: 2009-06-23T12:42:23Z" .



###  http://purl.obolibrary.org/obo/OGMS_0000104

obo:OGMS_0000104 rdf:type owl:Class ;
                 
                 rdfs:label "diagnostic process" ;
                 
                 rdfs:subClassOf obo:BFO_0000015 ;
                 
                 obo:IAO_0000412 "http://purl.obolibrary.org/obo/cido.owl" ;
                 
                 obo:IAO_0000115 "An interpretive process that has as input a clinical picture of a given patient and as output an assertion to the effect that the patient has a disease, disorder, or syndrome of a certain type, or none of these."@en ;
                 
                 obo:IAO_0000232 "creation date: 2011-09-20T09:57:44Z" ;
                 
                 obo:IAO_0000119 "http://groups.google.com/group/ogms-discuss/browse_thread/thread/2a7008f311fac766/e7de486c94dfd82e" ;
                 
                 obo:IAO_0000117 "Albert Goldfain" .



###  http://purl.obolibrary.org/obo/OGMS_0000123

obo:OGMS_0000123 rdf:type owl:Class ;
                 
                 rdfs:label "clinical data item"@en ;
                 
                 rdfs:subClassOf obo:IAO_0000027 ;
                 
                 obo:IAO_0000232 "creation date: 2018-11-27" ;
                 
                 obo:IAO_0000412 "https://github.com/OGMS/ogms/releases/tag/2021-04-20" ;
                 
                 obo:IAO_0000115 "A data item that is about a patient and is the specified output of a health care process assay or diagnostic process" .



###  http://purl.obolibrary.org/obo/OMRSE_00000011

obo:OMRSE_00000011 rdf:type owl:Class ;
                   
                   rdfs:label "patient role"@en ;
                   
                   rdfs:subClassOf obo:BFO_0000023 ;
                   
                   obo:IAO_0000115 "A role borne by an organism and that is realized by presenting to a health care provider in a clinical encounter."@en ;
                   
                   obo:IAO_0000412 "http://purl.obolibrary.org/obo/omrse/releases/2021-04-21/omrse.owl" ;
                   
